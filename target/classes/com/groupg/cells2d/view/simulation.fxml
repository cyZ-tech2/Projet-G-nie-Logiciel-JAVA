<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="750.0" prefWidth="750.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.groupg.cells2d.controller.SimulationController">

    <top>
        <VBox alignment="CENTER" spacing="12" style="-fx-padding: 15;">
            <Label fx:id="statsLabel" text="Cliquez sur 'Créer la simulation' pour commencer."
                   style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;" />

            <HBox alignment="CENTER" spacing="15">
                <Button fx:id="createButton" text="Créer simulation" onAction="#handleCreateSimulation"
                        style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand;" />

                <Button fx:id="startButton" text="Démarrer simulation" onAction="#handleStartSimulation" disable="true"
                        style="-fx-background-color: #2ecc71; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand;" />

                <Button fx:id="pauseButton" text="Pause / Reprendre" onAction="#handlePauseSimulation" disable="true"
                        style="-fx-background-color: #f39c12; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand;" />
            </HBox>
        </VBox>
    </top>

    <center>
        <GridPane fx:id="gridPane" alignment="CENTER" hgap="1" vgap="1"
                  style="-fx-background-color: #34495e; -fx-padding: 15;" />
    </center>

</BorderPane>
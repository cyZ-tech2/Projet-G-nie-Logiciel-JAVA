<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Menu?>
<?import javafx.scene.control.MenuBar?>
<?import javafx.scene.control.MenuItem?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.groupg.cells2d.controller.DoctorInterfaceController">

   <top>
      <MenuBar>
         <menus>
            <Menu mnemonicParsing="false" text="File">
               <items>
                  <MenuItem mnemonicParsing="false" text="Close" />
               </items>
            </Menu>
            <Menu mnemonicParsing="false" text="Help">
               <items>
                  <MenuItem mnemonicParsing="false" text="About" />
               </items>
            </Menu>
         </menus>
      </MenuBar>
   </top>

   <!-- Carte centrale (lecture seule, sélection de cellule) -->
   <center>
      <StackPane fx:id="mapPane" prefHeight="800.0" prefWidth="1000.0"
                 style="-fx-background-color: white;" BorderPane.alignment="CENTER">
         <children>
            <ImageView fx:id="mapImageView" preserveRatio="true" smooth="true" />
            <Pane fx:id="districtLayer" pickOnBounds="false" prefHeight="800.0" prefWidth="1000.0" />
            <Pane fx:id="gridLayer"     pickOnBounds="false" prefHeight="800.0" prefWidth="1000.0" />
         </children>
      </StackPane>
   </center>

   <!-- Panneau gauche -->
   <left>
      <VBox prefHeight="1080.0" prefWidth="300.0" spacing="10.0" style="-fx-padding: 10;">
         <children>

            <!-- Contrôles simulation -->
            <Label style="-fx-font-weight: bold; -fx-font-size: 13;" text="Simulation" />
            <HBox spacing="6.0">
               <children>
                  <Button fx:id="btnPlay"  onAction="#onPlay"  prefWidth="85" text="▶ Play" />
                  <Button fx:id="btnPause" onAction="#onPause" prefWidth="85" text="⏸ Pause" />
                  <Button fx:id="btnStop"  onAction="#onStop"  prefWidth="85" text="⏹ Stop" />
               </children>
            </HBox>
            <Label fx:id="stepLabel"   text="Étape : 0" />
            <Label fx:id="statusLabel" text="Statut : IDLE" />

            <Separator>
               <VBox.margin><Insets bottom="5.0" top="5.0" /></VBox.margin>
            </Separator>

            <!-- Formulaire patient -->
            <Label style="-fx-font-weight: bold; -fx-font-size: 13;" text="Ajouter un cas patient" />
            <Label text="ID cas (auto)" style="-fx-font-size: 11; -fx-text-fill: #666;" />
            <TextField fx:id="caseIdField" promptText="ID du cas (auto)" editable="false"
                       style="-fx-background-color: #f0f0f0;" />
            <ComboBox fx:id="ageGroupCombo" promptText="Groupe d'âge" maxWidth="Infinity" />
            <TextField fx:id="symptomsField" promptText="Symptômes (séparés par virgule)" />
            <TextField fx:id="caseCountField" promptText="Nombre de cas infectés" />
            <Label fx:id="selectedCellLabel"
                   text="👆 Cliquez sur la carte pour sélectionner la cellule"
                   wrapText="true" style="-fx-font-size: 11; -fx-text-fill: #444;" />
            <Button fx:id="addCaseButton" mnemonicParsing="false" onAction="#submitCase"
                    text="Ajouter le cas" maxWidth="Infinity" />

            <Separator>
               <VBox.margin><Insets bottom="5.0" top="5.0" /></VBox.margin>
            </Separator>

            <Button mnemonicParsing="false" onAction="#onShowStatisticsCharts"
                    text="📊 Graphiques" maxWidth="Infinity" />

         </children>
      </VBox>
   </left>

</BorderPane>

<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Menu?>
<?import javafx.scene.control.MenuBar?>
<?import javafx.scene.control.MenuItem?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.Slider?>
<?import javafx.scene.control.ToolBar?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.image.ImageView?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.groupg.cells2d.controller.ResearcherController">
   <top>
      <MenuBar>
        <menus>
          <Menu mnemonicParsing="false" text="File">
            <items>
              <MenuItem mnemonicParsing="false" text="New" />
              <MenuItem mnemonicParsing="false" text="Open" />
              <MenuItem mnemonicParsing="false" text="Save" />
              <MenuItem mnemonicParsing="false" text="Close" />
            </items>
          </Menu>
          <Menu mnemonicParsing="false" text="Simulation">
            <items>
              <MenuItem mnemonicParsing="false" text="Start" onAction="#onPlay"/>
              <MenuItem mnemonicParsing="false" text="Pause" onAction="#onPause"/>
              <MenuItem mnemonicParsing="false" text="Reset" onAction="#onStop"/>
            </items>
          </Menu>
          <Menu mnemonicParsing="false" text="Help">
            <items>
              <MenuItem mnemonicParsing="false" text="About" />
            </items>
          </Menu>
        </menus>
      </MenuBar>
   </top>

   <left>
      <VBox spacing="10.0" prefWidth="310.0" BorderPane.alignment="CENTER">
         <padding>
            <Insets top="10.0" right="10.0" bottom="10.0" left="10.0" />
         </padding>
         <children>
            <!-- Simulation controls -->
            <Label text="Contrôles" style="-fx-font-weight: bold; -fx-font-size: 13;" />
            <HBox spacing="6.0">
               <children>
                  <Button fx:id="btnPlay"  text="▶ Play"  onAction="#onPlay"  prefWidth="70"/>
                  <Button fx:id="btnPause" text="⏸ Pause" onAction="#onPause" prefWidth="70"/>
                  <Button fx:id="btnStop"  text="⏹ Stop"  onAction="#onStop"  prefWidth="70"/>
                  <Button fx:id="btnStep"  text="→ Step"  onAction="#onStep"  prefWidth="70"/>
               </children>
            </HBox>

            <!-- Status info -->
            <Label fx:id="stepLabel"   text="Étape: 0"       style="-fx-font-size: 12;"/>
            <Label fx:id="statusLabel" text="Statut: IDLE"   style="-fx-font-size: 12;"/>
            
            <!--Statistics-->
            <Label text="Statistiques"
            style="-fx-font-weight: bold; -fx-font-size: 13;" />

            <Label fx:id="statsLabel" wrapText="true" prefWidth="280.0"/>
            <Separator prefWidth="280.0" />

            <Button text="📊 Graphiques" onAction="#onShowStatisticsCharts" prefWidth="280.0"/>

            <!-- SEIR params -->
            <Label text="Paramètres SEIR" style="-fx-font-weight: bold; -fx-font-size: 13;" />

            <Label fx:id="betaLabel" text="β (transmission): 0.30" />
            <Slider fx:id="betaSlider" min="0.0" max="1.0" value="0.3" showTickLabels="true" showTickMarks="true" prefWidth="280.0"/>

            <Label fx:id="gammaLabel" text="γ (guérison): 0.10" />
            <Slider fx:id="gammaSlider" min="0.0" max="0.5" value="0.1" showTickLabels="true" showTickMarks="true" prefWidth="280.0"/>

            <Separator prefWidth="280.0" />

            <!-- Légende -->
            <Label text="Légende" style="-fx-font-weight: bold; -fx-font-size: 13;" />
            <HBox spacing="6" alignment="CENTER_LEFT">
               <Pane prefWidth="16" prefHeight="16" style="-fx-background-color: rgba(89,180,90,0.6);"/>
               <Label text="Sain (HEALTHY)"/>
            </HBox>
            <HBox spacing="6" alignment="CENTER_LEFT">
               <Pane prefWidth="16" prefHeight="16" style="-fx-background-color: rgba(255,193,7,0.8);"/>
               <Label text="Partiel (PARTIAL)"/>
            </HBox>
            <HBox spacing="6" alignment="CENTER_LEFT">
               <Pane prefWidth="16" prefHeight="16" style="-fx-background-color: rgba(220,53,69,0.9);"/>
               <Label text="Infecté (INFECTED)"/>
            </HBox>
            <HBox spacing="6" alignment="CENTER_LEFT">
               <Pane prefWidth="16" prefHeight="16" style="-fx-background-color: rgba(33,150,243,0.8);"/>
               <Label text="Critique (CRITICAL)"/>
            </HBox>

            <Separator prefWidth="280.0" />

            <!-- Cell info -->
            <Label text="Cellule sélectionnée" style="-fx-font-weight: bold;"/>
            <Label fx:id="selectedCellLabel" wrapText="true" text="Clique sur une cellule dans Paris." prefWidth="280.0"/>
         </children>
      </VBox>
   </left>

   <center>
      <StackPane fx:id="mapPane" prefHeight="800.0" prefWidth="1000.0"
                 style="-fx-background-color: white;" BorderPane.alignment="CENTER">
         <children>
            <ImageView fx:id="mapImageView" preserveRatio="true" smooth="true" />
            <Pane fx:id="districtLayer" prefWidth="1000.0" prefHeight="800.0" pickOnBounds="false" />
            <Pane fx:id="gridLayer"     prefWidth="1000.0" prefHeight="800.0" pickOnBounds="false" />
         </children>
      </StackPane>
   </center>
</BorderPane>
